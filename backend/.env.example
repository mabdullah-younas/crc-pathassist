# CRC-PathAssist Backend — Environment Configuration
#
# Copy this file to .env and adjust values if needed.
# All inference runs locally via Ollama — no cloud API keys required.

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name — must match what you pulled
OLLAMA_MODEL=gemma4:e4b
